# Exclude large data files that are already bundled into the code
data/

# Exclude build artifacts
.next/
node_modules/

# Exclude development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Exclude git and version control
.git/
.gitignore

# Exclude other development files
.eslintignore
.prettierignore
tsconfig.json
postcss.config.mjs
tailwind.config.ts

# Exclude development scripts
scripts/
